<Window x:Class="Asterism.Client.Views.ExecutablePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="実行ファイルの選択" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="パッケージ内に複数の実行ファイル（.exe）が見つかりました。使用するものを選択してください。"
                   TextWrapping="Wrap" Margin="0,0,0,10" />
        <ListBox x:Name="CandidatesListBox" MaxHeight="300"
                 MouseDoubleClick="OnListBoxDoubleClick" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="選択" Width="80" Click="OnSelectClick" IsDefault="True"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="キャンセル" Width="80" Margin="8,0,0,0" Click="OnCancelClick" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>

<Window x:Class="Asterism.Client.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="使い方" Height="620" Width="640"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#4F46E5" />
            <Setter Property="Margin" Value="0,20,0,6" />
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Foreground" Value="#333333" />
        </Style>
        <Style x:Key="Bullet" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="20" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="Margin" Value="12,2,0,0" />
        </Style>
        <Style x:Key="KeyLabel" TargetType="Border">
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,16,24,8">
            <StackPanel>

                <!-- ツール一覧・検索 -->
                <TextBlock Style="{StaticResource SectionHeader}" Margin="0,4,0,6">ツールの一覧・検索</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 登録されたツールがカード形式で一覧表示されます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 上部の検索ボックスにキーワードを入力すると、名前・説明・タグで絞り込めます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 左のサイドバーでカテゴリを選択して絞り込めます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「インストール済み」を選ぶと導入済みのツールのみ表示されます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「★ お気に入り」でお気に入り登録したツールのみ表示されます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 右上の「並び替え」で名前順・カテゴリ順・更新あり優先に切り替えられます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• カードのタグをクリックすると、そのタグで検索が実行されます。</TextBlock>

                <!-- インストール・起動・更新 -->
                <TextBlock Style="{StaticResource SectionHeader}">インストール・起動・更新</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「インストール」ボタンを押すとZIPをサーバーからダウンロードして展開します。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• インストール後は「起動」ボタンでツールを直接起動できます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• サーバー側でバージョンが上がると「更新あり」バッジとオレンジ枠が表示されます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「更新」ボタンを押すと最新バージョンをダウンロードして上書きインストールします。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「アンインストール」ボタンでインストールフォルダごと削除できます。</TextBlock>

                <!-- インストール先 -->
                <TextBlock Style="{StaticResource SectionHeader}">インストール先フォルダ</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 画面下部に現在のインストール先フォルダのパスが表示されます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}" Margin="12,2,0,0">既定: <Run FontWeight="SemiBold">%USERPROFILE%\Downloads\Asterism\</Run></TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「変更」ボタンで任意のフォルダに変更できます（設定はアプリ再起動後も保持されます）。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「フォルダを開く」でエクスプローラーを開けます。</TextBlock>

                <!-- お気に入り -->
                <TextBlock Style="{StaticResource SectionHeader}">お気に入り</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• カード右上の「☆」をクリックするとお気に入りに登録されます（★ に変わります）。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• もう一度クリックするとお気に入りを解除できます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• お気に入りはローカルに保存され、アプリ再起動後も保持されます。</TextBlock>

                <!-- 自動更新確認 -->
                <TextBlock Style="{StaticResource SectionHeader}">自動更新確認</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• バックグラウンドで定期的にサーバーの最新情報を確認します（既定: 10分間隔）。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 新しい更新が見つかると、画面上部のバナーとシステムトレイのバルーン通知でお知らせします。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 右上の「更新を確認」ボタンを押すと即時確認できます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 更新確認の間隔は <Run FontWeight="SemiBold">appsettings.json</Run> の <Run FontWeight="SemiBold">PollingIntervalMinutes</Run> で変更できます。</TextBlock>

                <!-- システムトレイ -->
                <TextBlock Style="{StaticResource SectionHeader}">システムトレイ</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• ウィンドウの × ボタンを押すと画面が閉じますが、アプリはシステムトレイで動き続けます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• トレイアイコンをダブルクリック、または右クリック→「Asterism を開く」でウィンドウを再表示できます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 右クリック→「終了」を選択するとアプリを完全に終了できます。</TextBlock>

                <!-- 管理者モード -->
                <TextBlock Style="{StaticResource SectionHeader}">管理者モード（ツール登録・編集）</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• メニューバーの「ツール → 管理者モード」から管理者パスワードでロックを解除します。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 管理者モードではツールの新規登録・編集・削除ができます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 新規登録時にZIPファイルを選択するとID・配布形式が自動入力されます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 「無効化」チェックを入れると、そのツールを一般ユーザーの一覧から非表示にできます。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}">• 削除はmanifest.jsonからエントリを除くのみで、サーバー上のZIPファイルは残ります。</TextBlock>
                <TextBlock Style="{StaticResource Bullet}" Margin="12,2,0,24">• 管理者パスワードはサーバーの <Run FontWeight="SemiBold">appsettings.json</Run> の <Run FontWeight="SemiBold">Asterism:AdminApiKey</Run> で設定します。</TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- フッター -->
        <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="24,10">
            <Button Content="閉じる" Width="80" HorizontalAlignment="Right"
                    Padding="0,6" Click="OnCloseClick" IsDefault="True" />
        </Border>
    </Grid>
</Window>

<Window x:Class="Asterism.Client.Views.AdminToolEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel>
            <TextBlock Text="パッケージファイル（.zip）（新規登録時は必須。編集時は未選択なら既存ファイルを維持。アイコンは実行ファイルパスの.exeから自動取得されます）" FontWeight="Bold" TextWrapping="Wrap" />
            <Grid Margin="0,2,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="ファイルを選択" Padding="8,4" Click="OnSelectPackageClick" />
                <TextBlock Grid.Column="1" Text="{Binding PackageFilePath}" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                        Visibility="{Binding IconPreview, Converter={StaticResource NullToVisibilityConverter}}">
                <Border Width="40" Height="40" BorderThickness="1" BorderBrush="#DDDDDD" CornerRadius="6">
                    <Image Source="{Binding IconPreview}" Width="32" Height="32" />
                </Border>
                <TextBlock Text="アイコンプレビュー" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11" Foreground="Gray" />
            </StackPanel>

            <TextBlock Text="ID" FontWeight="Bold" />
            <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsIdReadOnly}" Margin="0,2,0,10" Padding="4" />

            <TextBlock Text="名前" FontWeight="Bold" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4" />

            <TextBlock Text="バージョン" FontWeight="Bold" />
            <TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4" />

            <TextBlock Text="説明" FontWeight="Bold" />
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4"
                     TextWrapping="Wrap" AcceptsReturn="True" Height="60" />

            <TextBlock Text="カテゴリ" FontWeight="Bold" />
            <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4" />

            <TextBlock Text="タグ（カンマ区切り）" FontWeight="Bold" />
            <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" Padding="4" />

            <TextBlock Text="実行ファイルパス（展開後フォルダからの相対パス）" FontWeight="Bold" TextWrapping="Wrap" />
            <Grid Margin="0,2,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ExecutablePath, UpdateSourceTrigger=PropertyChanged}" Padding="4" />
                <Button Grid.Column="1" Content="選択..." Padding="8,4" Margin="6,0,0,0" Click="OnSelectExecutableClick" />
            </Grid>

            <CheckBox Content="このツールを無効化する（一般ユーザーの一覧に表示しない）"
                      IsChecked="{Binding IsDisabled}" Margin="0,0,0,10" />

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,4,0,10"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="保存" Width="80" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}" />
                <Button Content="キャンセル" Width="80" Margin="8,0,0,0" Click="OnCancelClick" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>

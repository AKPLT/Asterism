<Window x:Class="Asterism.Client.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理者モード - ツール管理" Height="560" Width="900"
        AllowDrop="True" DragEnter="OnWindowDragEnter" Drop="OnWindowDrop">
    <DockPanel>
    <Menu DockPanel.Dock="Top">
        <MenuItem Header="ヘルプ">
            <MenuItem Header="使い方（管理者）" Click="OnAdminHelpClick" />
        </MenuItem>
    </Menu>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="新規登録" DockPanel.Dock="Right" Padding="10,4" Click="OnAddNewClick"
                    Style="{StaticResource PrimaryButton}" />
            <Button Content="更新" DockPanel.Dock="Right" Padding="10,4" Margin="0,0,8,0" Command="{Binding LoadCommand}" />
            <TextBlock Text="（ZIPファイルをこの画面にドラッグ&amp;ドロップしても登録できます）" DockPanel.Dock="Right"
                       Margin="0,0,16,0" VerticalAlignment="Center" Foreground="Gray" FontSize="11" />
            <TextBlock Text="検索:" DockPanel.Dock="Left" Margin="24,0,4,0" VerticalAlignment="Center" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Padding="6,4" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="✕" Padding="8,4" Margin="4,0,0,0"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding HasSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </DockPanel>

        <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,0,0,8" TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" Margin="0,0,8,0"
                     ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory}" />

            <ListView Grid.Column="1" ItemsSource="{Binding ToolsView}"
                      GridViewColumnHeader.Click="OnColumnHeaderClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="160" DisplayMemberBinding="{Binding Id}" />
                        <GridViewColumn Header="名前" Width="140" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="バージョン" Width="80" DisplayMemberBinding="{Binding Version}" />
                        <GridViewColumn Header="カテゴリ" Width="100" DisplayMemberBinding="{Binding Category}" />
                        <GridViewColumn Header="操作" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="編集" Padding="8,2" Click="OnEditClick" Tag="{Binding}" />
                                        <Button Content="削除" Padding="8,2" Margin="4,0,0,0" Click="OnDeleteClick" Tag="{Binding}"
                                                Style="{StaticResource DangerButton}" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
    </DockPanel>
</Window>

<Window x:Class="Asterism.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Asterism.Client.Views"
        mc:Ignorable="d"
        Title="Asterism" Height="640" Width="1000">
    <DockPanel>
    <Menu DockPanel.Dock="Top">
        <MenuItem Header="ツール">
            <MenuItem Header="管理者モード" Click="OnAdminModeClick" />
        </MenuItem>
        <MenuItem Header="ヘルプ">
            <MenuItem Header="使い方" Click="OnHelpClick" />
            <Separator />
            <MenuItem Header="バージョン情報" Click="OnAboutClick" />
        </MenuItem>
    </Menu>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ヘッダー: 検索 + 並び替え + 更新確認 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="更新を確認" DockPanel.Dock="Right" Padding="10,4" Margin="8,0,0,0"
                    Command="{Binding RefreshManifestCommand}" />
            <ComboBox DockPanel.Dock="Right" MinWidth="100" Padding="4,2" Margin="4,0,0,0"
                      VerticalContentAlignment="Center"
                      ItemsSource="{Binding SortOptionLabels, Mode=OneTime}"
                      SelectedItem="{Binding SelectedSortLabel}" />
            <TextBlock DockPanel.Dock="Right" Text="並び替え:" Margin="0,0,4,0" VerticalAlignment="Center" />
            <TextBlock Text="検索:" DockPanel.Dock="Left" Margin="0,0,4,0" VerticalAlignment="Center" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Padding="6,4" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="✕" Padding="8,4" Margin="4,0,0,0"
                        Command="{Binding ClearSearchCommand}"
                        Visibility="{Binding HasSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </DockPanel>

        <!-- バナー -->
        <Border Grid.Row="1" Margin="0,0,0,8" Padding="8" CornerRadius="4"
                Visibility="{Binding BannerMessage, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFF3CD" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBannerError}" Value="True">
                            <Setter Property="Background" Value="#F8D7DA" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding BannerMessage}" TextWrapping="Wrap" />
        </Border>

        <!-- 本体: カテゴリサイドバー + カード一覧 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" Margin="0,0,8,0"
                     ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding SelectedCategory}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding}" Value="__separator__">
                                <Setter Property="IsEnabled" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Separator Margin="4,4,4,4" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ToolsView}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:ToolCardView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
        <!-- フッター: インストール先 -->
        <DockPanel Grid.Row="3" Margin="0,6,0,0" LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="変更" Padding="8,2"
                    Command="{Binding ChangeInstallFolderCommand}" />
            <Button DockPanel.Dock="Right" Content="フォルダを開く" Padding="8,2" Margin="0,0,4,0"
                    Command="{Binding OpenInstallFolderCommand}" />
            <TextBlock DockPanel.Dock="Left" Text="インストール先: " VerticalAlignment="Center" FontSize="11" Foreground="Gray" />
            <TextBlock Text="{Binding InstallDirectory}" VerticalAlignment="Center"
                       FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </Grid>
    </DockPanel>
</Window>

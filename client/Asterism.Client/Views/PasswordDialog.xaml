<Window x:Class="Asterism.Client.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理者モード" Height="200" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="管理者パスワードを入力してください" Margin="0,0,0,8" />
        <PasswordBox x:Name="PasswordInput" Padding="6,4" />
        <TextBlock x:Name="ErrorText" Foreground="Red" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Click="OnOkClick" IsDefault="True" />
            <Button Content="キャンセル" Width="80" Margin="8,0,0,0" Click="OnCancelClick" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>

<Application x:Class="Asterism.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Asterism.Client"
             xmlns:conv="clr-namespace:Asterism.Client.Converters">
    <Application.Resources>
        <conv:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:StringToBrushConverter x:Key="StringToBrushConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Application.Resources>
</Application>

<Window x:Class="Asterism.Client.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="バージョン情報" Height="260" Width="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- アプリ名・バージョン -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="48" Height="48" CornerRadius="10" Background="#4F46E5" Margin="0,0,14,0">
                <TextBlock Text="A" FontSize="26" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Asterism" FontSize="22" FontWeight="Bold" />
                <TextBlock x:Name="VersionText" FontSize="12" Foreground="Gray" Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- 説明 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="社内ツールのダウンロード・更新・起動を一元管理するポータルアプリです。"
                       TextWrapping="Wrap" Foreground="#444444" LineHeight="20" />
        </StackPanel>

        <!-- 閉じるボタン -->
        <Button Grid.Row="2" Content="閉じる" Width="80"
                HorizontalAlignment="Right" Padding="0,6"
                Click="OnCloseClick" IsDefault="True" />
    </Grid>
</Window>

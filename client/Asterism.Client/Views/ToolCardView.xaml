<UserControl x:Class="Asterism.Client.Views.ToolCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Asterism.Client.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ToolCardViewModel}"
             Width="380" Margin="6">
    <Border BorderThickness="1" CornerRadius="6" Background="White" Padding="10"
            Cursor="Hand" MouseLeftButtonUp="OnCardClick">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#DDDDDD" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                        <Setter Property="BorderBrush" Value="#F59E0B" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- アイコン -->
            <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,10,0" VerticalAlignment="Top">
                <Border CornerRadius="8"
                        Background="{Binding InitialColor, Converter={StaticResource StringToBrushConverter}}"
                        Visibility="{Binding NoIcon, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding InitialLetter}" FontSize="18" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Image Source="{Binding IconUrl, Converter={StaticResource StringToImageSourceConverter}}"
                       Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <!-- コンテンツ -->
            <StackPanel Grid.Column="1">

                <!-- 名前行: バッジ・★ -->
                <DockPanel>
                    <Button DockPanel.Dock="Right" Command="{Binding ToggleFavoriteCommand}"
                            Padding="4,0,0,0" Cursor="Hand" FontSize="15" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="☆" />
                                <Setter Property="Foreground" Value="#AAAAAA" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Content" Value="★" />
                                        <Setter Property="Foreground" Value="#F59E0B" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Border DockPanel.Dock="Right" Background="#F59E0B" CornerRadius="4" Padding="5,1" Margin="4,0,4,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="更新あり" FontSize="10" FontWeight="Bold" Foreground="White" />
                    </Border>
                    <Border DockPanel.Dock="Right" Background="#059669" CornerRadius="4" Padding="5,1" Margin="4,0,4,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLatest, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="最新" FontSize="10" FontWeight="Bold" Foreground="White" />
                    </Border>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </DockPanel>

                <!-- カテゴリ・バージョン -->
                <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="Gray" />
                    <TextBlock Text=" · " FontSize="11" Foreground="Gray" />
                    <TextBlock Text="{Binding VersionText, StringFormat='v{0}'}" FontSize="11" Foreground="Gray" />
                </StackPanel>

                <!-- 説明 (1行) -->
                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#555555"
                           TextTrimming="CharacterEllipsis" Margin="0,3,0,0"
                           MaxHeight="18" />

                <!-- タグ -->
                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectTagCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand" Margin="0,0,4,2"
                                    Background="Transparent" BorderThickness="0" Padding="0">
                                <Border Background="#EEEEEE" CornerRadius="8" Padding="6,1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver,
                                                    RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                    <Setter Property="Background" Value="#D1D5DB" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding}" FontSize="10" />
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- プログレス・エラー -->
                <ProgressBar Height="4" Margin="0,4,0,0" Minimum="0" Maximum="1"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                <!-- ボタン -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{Binding PrimaryButtonLabel}"
                            Command="{Binding PrimaryActionCommand}" Padding="0,4" FontSize="12"
                            Style="{StaticResource ToolCardPrimaryButton}" />
                    <Button Grid.Column="1" Content="アンインストール" Margin="6,0,0,0" Padding="8,4" FontSize="12"
                            Command="{Binding UninstallCommand}"
                            Style="{StaticResource DangerButton}" />
                </Grid>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>

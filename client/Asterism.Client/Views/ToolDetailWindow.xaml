<Window x:Class="Asterism.Client.Views.ToolDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Name}" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="640">
        <StackPanel Margin="20">

            <!-- ヘッダー: アイコン・名前・バージョン・バッジ -->
            <DockPanel Margin="0,0,0,14">
                <Grid DockPanel.Dock="Left" Width="48" Height="48" Margin="0,0,14,0">
                    <Border CornerRadius="10"
                            Background="{Binding InitialColor, Converter={StaticResource StringToBrushConverter}}"
                            Visibility="{Binding NoIcon, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding InitialLetter}" FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Image Source="{Binding IconUrl, Converter={StaticResource StringToImageSourceConverter}}"
                           Visibility="{Binding HasIcon, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
                <StackPanel VerticalAlignment="Center">
                    <DockPanel>
                        <Border DockPanel.Dock="Left" Background="#F59E0B" CornerRadius="4" Padding="5,1" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="更新あり" FontSize="10" FontWeight="Bold" Foreground="White" />
                        </Border>
                        <Border DockPanel.Dock="Left" Background="#059669" CornerRadius="4" Padding="5,1" Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsLatest, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="最新" FontSize="10" FontWeight="Bold" Foreground="White" />
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                    </DockPanel>
                    <TextBlock Margin="0,3,0,0" Foreground="Gray" FontSize="12">
                        <Run Text="{Binding Category, Mode=OneWay}" />
                        <Run Text=" · v" />
                        <Run Text="{Binding VersionText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>

            <!-- 説明（全文） -->
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" LineHeight="20"
                       Margin="0,0,0,14" />

            <!-- タグ -->
            <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,14">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#EEEEEE" CornerRadius="8" Padding="6,2" Margin="0,0,6,6">
                            <TextBlock Text="{Binding}" FontSize="11" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- プログレス・エラー -->
            <ProgressBar Height="4" Margin="0,0,0,10" Minimum="0" Maximum="1"
                         Value="{Binding ProgressPercent, Mode=OneWay}"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,10"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

            <!-- ボタン -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="{Binding PrimaryButtonLabel}"
                        Command="{Binding PrimaryActionCommand}" Padding="0,8"
                        Style="{StaticResource ToolCardPrimaryButton}" />
                <Button Grid.Column="1" Content="アンインストール" Margin="8,0,0,0" Padding="10,8"
                        Command="{Binding UninstallCommand}"
                        Style="{StaticResource DangerButton}" />
                <Button Grid.Column="2" Content="閉じる" Margin="8,0,0,0" Padding="10,8"
                        Click="OnCloseClick" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
